# ============================================================
# AzureAIArchitect — Environment Configuration
# cp .env.example .env  then fill in your values
# ============================================================

# -----------------------------------------------------------
# Azure OpenAI  (REQUIRED — powers all agents)
# -----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Alternative: standard OpenAI (used if Azure vars are not set)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------
# Azure Monitor  (OPTIONAL — enhanced telemetry)
# -----------------------------------------------------------
# AZURE_MONITOR_CONNECTION_STRING=InstrumentationKey=00000000-...

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------
# File handling
# -----------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
OUTPUT_DIR=./generated

# -----------------------------------------------------------
# Agent behaviour
# -----------------------------------------------------------
AGENT_MAX_TOKENS=4000
AGENT_MAX_RETRIES=3
AGENT_RETRY_BASE_DELAY_MS=1000
